{
  "name": "daodaocrazy-portfolio",
  "version": "1.0.0",
  "description": "Daodaocrazy's AI Native Personal Workspace - VitePress, React, Tools & Experiments",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:build:lab": "BASE_URL=/lab vitepress build docs",
