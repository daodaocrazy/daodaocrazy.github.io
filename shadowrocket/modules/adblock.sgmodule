#!name=Ultimate iOS AdBlock
#!desc=AntiAD + AWAvenue + AdGuard + EasyList + Custom CN AdBlock
#!author=custom
#!version=3.0

########################################
# Remote AdBlock Rules (Auto Update)
########################################

[Rule]

# Anti-AD 国内最强广告规则
RULE-SET,https://raw.githubusercontent.com/privacy-protection-tools/anti-AD/master/anti-ad-sr.txt,REJECT

# 秋风广告规则
RULE-SET,https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/main/Shadowrocket/Ads.conf,REJECT

# AdGuard Mobile Ads
RULE-SET,https://raw.githubusercontent.com/AdguardTeam/AdguardFilters/master/MobileFilter/sections/adservers.txt,REJECT

# EasyList China
RULE-SET,https://easylist-downloads.adblockplus.org/easylistchina.txt,REJECT

# 大圣广告规则
RULE-SET,https://raw.githubusercontent.com/lmfstar/adblock-rules/master/surge.txt,REJECT


########################################
# Tencent Ads (广点通)
########################################

DOMAIN-SUFFIX,gdt.qq.com,REJECT
DOMAIN-SUFFIX,e.qq.com,REJECT
DOMAIN-SUFFIX,ad.qq.com,REJECT
DOMAIN-SUFFIX,adsmind.qq.com,REJECT


########################################
# QQ Music Ads (QQ音乐广告拦截 - 增强版)
########################################

# ========== 通配域名后缀 ==========
# 腾讯广告素材与分发
DOMAIN-SUFFIX,ugdtimg.com,REJECT
DOMAIN-SUFFIX,gtimg.cn,REJECT
DOMAIN-SUFFIX,l.qq.com,REJECT

# 腾讯音乐广告系统 (TME AD)
DOMAIN-SUFFIX,tmead.y.qq.com,REJECT
DOMAIN-SUFFIX,tmeadquic.y.qq.com,REJECT
DOMAIN-SUFFIX,tmeadbak.y.qq.com,REJECT
DOMAIN-SUFFIX,qkcdn6-media.tencentmusic.com,REJECT

# 腾讯系统计与测速
DOMAIN-SUFFIX,trace.qq.com,REJECT
DOMAIN-SUFFIX,tpstelemetry.tencentmusic.com,REJECT

# ========== 关键词匹配 ==========
# 拦截所有包含广告特征词的域名
DOMAIN-KEYWORD,adsmind,REJECT
DOMAIN-KEYWORD,admgr,REJECT
DOMAIN-KEYWORD,adv.music,REJECT
DOMAIN-KEYWORD,adstats,REJECT
DOMAIN-KEYWORD,monitor.music,REJECT

# ========== URL正则拦截 ==========
# 拦截开屏广告配置请求
URL-REGEX,^https?:\/\/.*\.y\.qq\.com\/.*(adv|splash|pre_load),REJECT

# ========== 具体域名补充 ==========
DOMAIN,u6.y.qq.com,REJECT
DOMAIN,oth.bls.mdt.qq.com,REJECT
DOMAIN,stat6.y.qq.com,REJECT
DOMAIN,m.cn.miaozhen.com,REJECT


########################################
# ByteDance Ads (穿山甲)
########################################

DOMAIN-SUFFIX,pangolin-sdk-toutiao.com,REJECT
DOMAIN-SUFFIX,pangolin-sdk-toutiao1.com,REJECT
DOMAIN-SUFFIX,ctobsnssdk.com,REJECT
DOMAIN-SUFFIX,bytescm.com,REJECT
DOMAIN-SUFFIX,snssdk.com,REJECT


########################################
# Sigmob Ads
########################################

DOMAIN-SUFFIX,sigmob.cn,REJECT
DOMAIN-SUFFIX,sigmob.com,REJECT


########################################
